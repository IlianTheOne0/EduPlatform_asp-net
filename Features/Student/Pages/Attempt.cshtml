@page "{id:int}"
@model TestingPlatform.Features.Student.Pages.AttemptModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Taking Test";

    var timeLimit = Model.Attempt.TestSession!.Test!.TimeLimitMinutes;

    var endTimeMs = timeLimit > 0 ? ((DateTimeOffset)Model.Attempt.StartedAt.AddMinutes(timeLimit)).ToUnixTimeMilliseconds() : 0;

    short questionIndex = 0;
}
<div class="sec">
    <p class="sec-lbl">@Model.Attempt.TestSession!.Test!.Title</p>
    <div class="cgrd" style="background:var(--sf);">
        <div class="p6">
            <div class="df ac jb m5">
                <h4 style="margin:0;">@Model.Attempt.TestSession!.Test!.Title</h4>
                @if (timeLimit > 0)
                {
                    <div class="badge bdan2" style="display:flex; align-items:center; gap:8px; padding:8px 18px;">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>

                        <span id="timerDisplay" class="mono fw-bold">--:--</span>
                    </div>
                }
            </div>

            <form method="post" id="testForm">
                <input type="hidden" asp-for="Attempt.Id" />

                @foreach (var question in Model.Questions)
                {
                    <div class="m5">
                        <div class="df ac jb m3">
                            <h5 class="w5"><span class="muted me-2">@(questionIndex + 1).</span> @question.Text</h5>
                        </div>

                        <div class="df fc- g2">
                            <input type="hidden" name="Answers[@questionIndex].QuestionId" value="@question.Id" />
                            
                            @foreach (var option in question.AnswerOptions)
                            {
                                <label class="ocard">
                                    <div class="odot"></div>
                                    <input class="form-check-input d-none" type="radio" name="Answers[@questionIndex].SelectedOptionId" value="@option.Id" data-question-id="@question.Id" required>
                                    <span>@option.Text</span>
                                </label>
                            }
                        </div>
                    </div>

                    questionIndex++;
                }

                <div class="df je mt6">
                    <button type="submit" class="btn bp lg">
                        Submit Assessment
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        const form = document.getElementById("testForm");
        const attemptId = @Model.Attempt.Id;
        const token = form.querySelector('input[name="__RequestVerificationToken"]').value;

        const timeLimit = @(timeLimit);
        const endTime = @(endTimeMs);

        form.addEventListener
        (
            'change',
            function(event)
            {
                if (event.target.type === 'radio')
                {
                    const optionId = event.target.value;
                    const questionId = event.target.getAttribute('data-question-id');

                    if (questionId && optionId)
                    {
                        fetch
                        (
                            `?handler=AutoSave&id=${attemptId}`,
                            {
                                method: 'POST',
                                headers:
                                {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': token
                                },
                                body: JSON.stringify
                                (
                                    {
                                        questionId: parseInt(questionId),
                                        selectedOptionId: parseInt(optionId)
                                    }
                                )
                            }
                        )
                        .then(response => response.json())
                        .then(data => { if(!data.success) { console.warn("Autosave rejected (timeout)."); } })
                        .catch(error => console.error('Auto-save error:', error));
                    }
                }
            }
        );

        if (timeLimit > 0 && endTime > 0)
        {
            const timerDisplay = document.getElementById("timerDisplay");
            const testForm = document.getElementById("testForm");

            const timerInterval = setInterval(function() {
                const now = new Date().getTime();
                const distance = endTime - now;

                if (distance <= 0) {
                    clearInterval(timerInterval);
                    timerDisplay.innerHTML = "00:00";

                    const radios = testForm.querySelectorAll('input[type="radio"]');
                    radios.forEach(radio => radio.removeAttribute('required'));
                    testForm.submit();
                    return;
                }

                const minutes = Math.floor(distance / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                timerDisplay.innerHTML =
                    (minutes < 10 ? "0" + minutes : minutes) + ":" +
                    (seconds < 10 ? "0" + seconds : seconds);
            }, 1000);
        }
    </script>
}