@page "{id:int}"
@model TestingPlatform.Features.Student.Pages.ResultModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Test Results";

    double percentage = Model.Attempt.MaxPossibleScore > 0 ? ((double)Model.Attempt.TotalScore / Model.Attempt.MaxPossibleScore) * 100 : 0;
}

<div class="sec">
    <p class="sec-lbl">Test Results</p>
    <div class="card oh">
        <div class="rsblock">
            <div>
                <p class="xs-t uc lsw muted w7">Total Score</p>
                <h1 class="gt" style="font-size:2.75rem; margin:0;">
                    @Model.Attempt.TotalScore <span style="font-size:1.25rem; color:var(--t3);">/ @Model.Attempt.MaxPossibleScore</span>
                </h1>
            </div>

            <div class="ring" style="background:conic-gradient(var(--as) @(percentage * 3.6)deg, var(--br) @(percentage * 3.6)deg);">
                <span>@percentage.ToString("0.0")%</span>
            </div>
        </div>

        @if (Model.Attempt.TestSession.Test.ShowResultsAtEnd)
        {
            <div class="p5" style="padding-top:16px;">
                <h5 class="m4">Detailed Breakdown</h5>
                <div class="df fc- g3">
                    @foreach (var answer in Model.Attempt.Answers)
                    {
                        <div>
                            <p class="w6 m2">@answer.Question!.Text</p>
                            <div class="df fc- g2">
                                @foreach (var option in answer.Question.AnswerOptions)
                                {
                                    var isSelected = answer.SelectedOptionId == option.Id;
                                    var isCorrect = option.IsCorrect;
                                    string cardClass = "ocard";

                                    if (isCorrect) { cardClass = "ocard cor"; }
                                    else if (isSelected) { cardClass = "ocard wrg"; }
                                    else { cardClass = "ocard"; }

                                    <div class="@cardClass" style="justify-content:space-between;">
                                        <div class="df ac g3">
                                            <div class="odot"></div>
                                            <span>@option.Text</span>
                                        </div>

                                        <div class="df g2">
                                            @if (isSelected && !isCorrect) { <span class="bdg bdan2" style="font-size:.6875rem;">Your Answer</span> }
                                            @if (isCorrect) { <span class="bdg bsuc2" style="font-size:.6875rem;">Correct Answer</span> }
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(answer.Question.Explanation))
                                {
                                    <div class="explanation-container">
                                        <span class="explanation-label">Instructor Explanation:</span>
                                        <span class="explanation-text">@answer.Question.Explanation</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alt alw m5" style="margin:24px;">
                <svg class="alt-i" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>

                <span>
                    <strong>Detailed Results Hidden</strong> - The instructor has disabled detailed review.
                </span>
            </div>
        }

        <div class="p5 text-center" style="border-top:1px solid var(--br);">
            <a asp-page="Dashboard" class="btn bs">Back to Dashboard</a>
        </div>
    </div>
</div>