@page
@model TestingPlatform.Features.Tests.Pages.CreateModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create Draft";
}

<div class="sec">
    <p class="sec-lbl">Create Test Draft</p>
    <div class="auth-c" style="max-width:600px; margin:0 auto;">
        <div class="auth-top">
            <div class="auth-logo">
                <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
            </div>

            <h3 class="m1">New Test Draft</h3>
            <p class="sm-t muted">Tests begin as Drafts. Add questions and publish later.</p>
        </div>

        <div class="auth-body">
            <form method="post">
                <div class="m4">
                    <label asp-for="Input.Title" class="flbl">Title</label>
                    <input asp-for="Input.Title" class="fc" required />
                </div>

                <div class="m4">
                    <label asp-for="Input.Description" class="flbl">Description</label>
                    <textarea asp-for="Input.Description" class="fc" rows="3"></textarea>
                </div>

                <div class="g2c m4" style="gap:12px;">
                    <div>
                        <label asp-for="Input.CategoryId" class="flbl">Category</label>
                        <select asp-for="Input.CategoryId" class="fsel" required>
                            <option value="">-- Select Category --</option>

                            @foreach (var category in Model.Categories) { <option value="@category.Id">@category.Name</option> }
                        </select>
                    </div>
                    <div>
                        <label asp-for="Input.TimeLimitMinutes" class="flbl">Time Limit (Mins)</label>
                        <input asp-for="Input.TimeLimitMinutes" class="fc" type="number" min="0" placeholder="0 for unlimited" />
                    </div>
                </div>
                <div class="m5">
                    <label class="flbl">Settings</label>
                    <div class="df ac g2">
                        <input class="form-check-input" type="checkbox" role="switch" asp-for="Input.ShowResultsAtEnd" id="showResultsSwitch" />
                        <label class="form-check-label" for="showResultsSwitch">Show detailed results after submission</label>
                    </div>
                </div>
                <div class="df g2 jc">
                    <a asp-page="Index" class="btn bs wf">Cancel</a>
                    <button type="submit" class="btn bp wf">Create Draft</button>
                </div>
            </form>
        </div>
    </div>
</div>