@page
@model TestingPlatform.Features.Users.Pages.LoginModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Welcome Back";
}

<div class="sec">
    <p class="sec-lbl">Login</p>

    <div class="auth-c" style="max-width:500px; margin:0 auto;">
        <div class="auth-top">
            <div class="auth-logo">
                <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
            </div>

            <h3 class="m1">@ViewData["Title"]</h3>
            <p class="sm-t muted" style="margin:0">Sign in to your EduPlatform account</p>
        </div>

        <div class="auth-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="dan sm-t m3"></div>

                <div class="m4">
                    <label asp-for="Input.Email" class="flbl">Email address</label>
                    <input asp-for="Input.Email" class="fc" autocomplete="username" placeholder="you@example.com" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="dan sm-t mt2 df"></span>
                </div>

                <div class="m5">
                    <label asp-for="Input.Password" class="flbl">Password</label>
                    <input asp-for="Input.Password" class="fc" autocomplete="current-password" placeholder="••••••••" aria-required="true" />
                    <span asp-validation-for="Input.Password" class="dan sm-t mt2 df"></span>
                </div>

                <div class="df ac g2 m5">
                    <input type="checkbox" asp-for="Input.RememberMe" id="rememberMeCheck" />
                    <label asp-for="Input.RememberMe" class="sm-t sec-c">Keep me signed in</label>
                </div>

                <button type="submit" class="btn bp wf lg m4">Log in</button>

                <p class="tc sm-t muted mt4">
                    Don't have an account? <a asp-page="Register" class="w5 pri">Create one free</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}