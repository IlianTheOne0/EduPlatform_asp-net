@page
@model TestingPlatform.Features.Users.Pages.RegisterModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create Account";
}

<div class="sec">
    <p class="sec-lbl">Sign up</p>

    <div class="auth-c" style="max-width:500px; margin:0 auto;">
        <div class="auth-top">
            <div class="auth-logo">
                <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
                </svg>
            </div>
            <h3 class="m1">Create Account</h3>
            <p class="sm-t muted">Join EduPlatform as a student</p>
        </div>

        <div class="auth-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="dan sm-t m3"></div>

                <div class="g2c m4" style="gap:12px;">
                    <div>
                        <label asp-for="Input.FirstName" class="flbl">First Name</label>
                        <input asp-for="Input.FirstName" class="fc" required />
                        <span asp-validation-for="Input.FirstName" class="dan sm-t"></span>
                    </div>

                    <div>
                        <label asp-for="Input.LastName" class="flbl">Last Name</label>
                        <input asp-for="Input.LastName" class="fc" required />
                        <span asp-validation-for="Input.LastName" class="dan sm-t"></span>
                    </div>
                </div>

                <div class="m4">
                    <label asp-for="Input.DateOfBirth" class="flbl">Date of Birth</label>
                    <input asp-for="Input.DateOfBirth" class="fc" type="date" />
                    <span asp-validation-for="Input.DateOfBirth" class="dan sm-t"></span>
                </div>

                <div class="m4">
                    <label asp-for="Input.Email" class="flbl">Email Address</label>
                    <input asp-for="Input.Email" class="fc" autocomplete="username" placeholder="name@example.com" required />
                    <span asp-validation-for="Input.Email" class="dan sm-t"></span>
                </div>

                <div class="m4">
                    <label asp-for="Input.Password" class="flbl">Password</label>
                    <input asp-for="Input.Password" class="fc" type="password" autocomplete="new-password" required />
                    <span asp-validation-for="Input.Password" class="dan sm-t"></span>
                </div>

                <div class="m5">
                    <label asp-for="Input.ConfirmPassword" class="flbl">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="fc" type="password" autocomplete="new-password" required />
                    <span asp-validation-for="Input.ConfirmPassword" class="dan sm-t"></span>
                </div>

                <button type="submit" class="btn bp wf">Create Account</button>

                <p class="tc sm-t muted mt4">
                    Already have an account? <a asp-page="Login" class="pri">Sign in</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}