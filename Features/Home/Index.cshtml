@page
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";
}

<div class="sec" style="max-width: 900px; margin: 0 auto; padding-top: 30px;">
    <div class="hero card" style="border:none; min-height: auto; padding: 60px 40px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="position: relative; z-index: 1;">
            <div style="display:inline-flex;align-items:center;gap:8px;background:var(--aps);border:1px solid hsla(231,93%,66%,.25);border-radius:999px;padding:5px 14px;margin-bottom:16px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--ap)"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
                <span style="font-size:.8125rem;font-weight:600;color:var(--ap);letter-spacing:.02em;">Modern Testing Platform</span>
            </div>

            <h1 class="gt" style="font-size:clamp(2rem, 5vw, 3.5rem);font-weight:800;letter-spacing:-.05em;margin-bottom:12px;line-height:1.1;">EduPlatform</h1>

            <p style="font-size:1rem;color:var(--t2);max-width:520px;margin:0 auto 24px;line-height:1.6;">A secure, real-time testing platform built for educators and students. Create tests, launch live sessions, track results.</p>

            <div class="df g3 jc fw">
                @if (!User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Users/Register" class="btn bp xl">Get Started</a>
                    <a asp-page="/Users/Login" class="btn bs xl">Sign In</a>
                }
                else { <a asp-page="/Home/Index" class="btn bp xl">Go to Dashboard</a> }
            </div>
        </div>
    </div>
</div>