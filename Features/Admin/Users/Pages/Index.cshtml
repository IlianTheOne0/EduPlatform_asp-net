@page
@model TestingPlatform.Features.Admin.Users.Pages.IndexModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Users";
}

<div class="sec">
    <p class="sec-lbl">Manage Users</p>
    <div class="df ac jb m4">
        <h2 style="margin:0">Users</h2>
        <a asp-page="Create" class="btn bp sm">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Register New
        </a>
    </div>

    <div class="card oh">
        <div style="overflow-x:auto">
            <table class="tbl">
                <thead>
                    <tr>
                        <th style="padding-left:24px">Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Registered</th>
                        <th style="text-align:right; padding-right:24px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.UsersList.Any())
                    {
                        <tr>
                            <td colspan="5" class="tc p5 muted">No users found.</td>
                        </tr>
                    }
                    @foreach (var user in Model.UsersList)
                    {
                        <tr>
                            <td style="padding-left:24px">
                                <div class="df ac g3">
                                    <div class="uav" style="width:34px; height:34px; background:var(--gp);">@user.FullName.Substring(0, 1)</div>
                                    <span class="w6">@user.FullName</span>
                                </div>
                            </td>
                        
                            <td class="muted">@user.Email</td>
                            
                            <td>
                                @switch (user.Role)
                                {
                                    case "Administrator": { <span class="bdg bdan2">Administrator</span> } break;
                                    case "Teacher": { <span class="bdg binf">Teacher</span> } break;
                                    case "Student": { <span class="bdg bnt">Student</span> } break;
                                    default: { <span class="bdg">@user.Role</span> } break;
                                }
                            </td>

                            <td class="sm-t muted">@user.RegisteredAt.ToString("MMM dd, yyyy")</td>
                            
                            <td style="text-align:right; padding-right:24px">
                                <div class="df g2 je">
                                    <a asp-page="Edit" asp-route-id="@user.Id" class="btn bs sm">
                                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                        </svg>
                                        Edit
                                    </a>
                                    @if (user.Email != User.Identity?.Name)
                                    {
                                        <a asp-page="Delete" asp-route-id="@user.Id" class="btn bodan sm">
                                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                            </svg>
                                            Delete
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>