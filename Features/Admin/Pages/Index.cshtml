@page
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="sec">
    <p class="sec-lbl">Admin Dashboard</p>
    <div class="gauto">
        <div class="cglow card">
            <div class="p6">
                <div class="kico kip mb-4">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                    </svg>
                </div>

                <h4 class="m2">Staff & Students</h4>
                <p class="sm-t muted m5">View, edit, or remove users and onboard new members to the platform.</p>
                
                <div class="df g2">
                    <a asp-page="/Admin/Users/Index" class="btn bs wf">Manage Users</a>
                    <a asp-page="/Admin/Users/Create" class="btn bp wf">Register New</a>
                </div>
            </div>
        </div>
        <div class="cglow card">
            <div class="p6">
                <div class="kico kis mb-4">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                    </svg>
                </div>
                
                <h4 class="m2">Metadata & Tests</h4>
                <p class="sm-t muted m5">Manage global categories and oversee all test drafts across the platform.</p>

                <div class="df g2">
                    <a asp-page="/Admin/Categories/Index" class="btn bs wf">Categories</a>
                    <a asp-page="/Tests/Index" class="btn bp wf">All Tests</a>
                </div>
            </div>
        </div>
    </div>
</div>