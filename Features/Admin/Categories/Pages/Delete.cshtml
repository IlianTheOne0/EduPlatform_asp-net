@page "{id:int}"
@model TestingPlatform.Features.Admin.Categories.Pages.DeleteModel
@{
    Layout = "~/Features/Shared/_Layout.cshtml";
    ViewData["Title"] = "Delete Category";
}

<div class="sec">
    <p class="sec-lbl">Delete Category</p>
    <div style="max-width:500px; margin:0 auto;">
        <div class="card oh">
            <div class="dh">
                <div class="dh-icon">
                    <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                </div>
                
                <h3>Delete Category?</h3>
            </div>

            <div class="p5 text-center">
                <p class="m4">You are about to permanently delete <strong>"@Model.Category.Name"</strong>.</p>
                
                <div class="alt alw a1 m4" style="text-align:left;">
                    <svg class="alt-i" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                    <span><strong>Data Loss Warning:</strong> All tests, sessions, and student attempts will be permanently erased.</span>
                </div>

                <form method="post" class="df g3 jc">
                    <input type="hidden" asp-for="Category.Id" />
                    <a asp-page="Index" class="btn bs">Cancel</a>
                
                    <button type="submit" class="btn bdan">Permanently Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>